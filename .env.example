APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_ALERT_CHANNELS=daily
LOG_OPERATIONS_LEVEL=info
LOG_OPERATIONS_DAYS=30
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

 DB_CONNECTION=mysql
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=tailadmin_laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=
ERP_CACHE_STORE=file
ERP_CACHE_OPERATIONS_TTL=120
ERP_CACHE_DASHBOARD_TTL=120
ERP_CACHE_FINANCIAL_TTL=300
ERP_CACHE_CASHFLOW_TTL=300
ERP_CACHE_RECEIVABLES_TTL=300
ERP_CACHE_SPLIT_PAYMENT_TTL=180
ERP_STOCK_ENFORCE_MINIMUM=false
ERP_EXPORT_CHUNK_SIZE=1000
ERP_EXPORT_QUEUE=reports
ERP_EXPORT_TRIES=3
ERP_EXPORT_TIMEOUT=300
ERP_EXPORT_BACKOFF_SECONDS=10
ERP_EXPORT_RETRY_WINDOW_MINUTES=30
ERP_REPORT_WORKER_QUEUE=reports
ERP_REPORT_WORKER_SLEEP=1
ERP_REPORT_WORKER_TRIES=3
ERP_REPORT_WORKER_BACKOFF=10
ERP_REPORT_WORKER_TIMEOUT=300
ERP_REPORT_WORKER_MEMORY=512
ERP_REPORT_WORKER_MAX_JOBS=100
ERP_REPORT_WORKER_MAX_TIME=3600
ERP_QUEUE_PENDING_THRESHOLD=200
ERP_QUEUE_FAILED_THRESHOLD=1
ERP_QUEUE_FAILED_WINDOW_MINUTES=60
ERP_BACKUP_RETENTION_DAYS=14
ERP_ADMIN_NAME="Owner ERP"
ERP_ADMIN_EMAIL=admin@webstellar.local
ERP_ADMIN_PASSWORD=Admin12345!

MEMCACHED_HOST=127.0.0.1

